# Leave blank until the production domain is registered, verified, and approved.
# Intended future domain: https://almeidajunioradvogado.com.br
# Do not use a Vercel preview URL as the canonical site URL.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SITE_NAME="Almeida Junior Advogado"
NEXT_PUBLIC_INDEXING_ENABLED=false

# Reserved for future analytics. Keep disabled until production approval.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=

# Contact form delivery.
# Allowed values:
# - mock: local development/test only; never valid on Vercel preview or production.
# - email: uses the configured email provider.
# - disabled: rejects safely and shows WhatsApp/phone alternatives.
CONTACT_FORM_MODE=mock

CONTACT_EMAIL_TO=grimaldoalmeida.oab@gmail.com
CONTACT_EMAIL_FROM=
CONTACT_EMAIL_REPLY_TO=
# Keep blank until Resend domain verification is complete.
CONTACT_EMAIL_PROVIDER=
CONTACT_EMAIL_API_KEY=

# Visitor confirmation is prepared, but no visitor email field is collected yet.
CONTACT_VISITOR_CONFIRMATION_ENABLED=false

# Development/test throttling. In-memory throttling is not production-ready.
CONTACT_RATE_LIMIT_PROVIDER=memory
CONTACT_RATE_LIMIT_WINDOW_SECONDS=900
CONTACT_RATE_LIMIT_MAX_REQUESTS=5
CONTACT_RATE_LIMIT_SALT=

# External production-compatible rate limiting with Upstash Redis REST.
# Required when CONTACT_RATE_LIMIT_PROVIDER=upstash.
CONTACT_RATE_LIMIT_UPSTASH_REST_URL=
CONTACT_RATE_LIMIT_UPSTASH_REST_TOKEN=
